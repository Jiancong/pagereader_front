# Backend API host (no /api2 suffix; CORS must allow page2.top)
# Either naming works at build time (legacy Next vars are supported)
VITE_API_URL=https://page2.top
# NEXT_PUBLIC_API_BASE=https://page2.top

# Google OAuth Web client ID (omit to hide Google sign-in button)
VITE_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Tag Manager container (loads on site)
VITE_GTM_ID=GTM-TDZZXHT5
# NEXT_PUBLIC_GTM_ID=GTM-TDZZXHT5

# GA4 Measurement ID G-0Y4KL2PZ5Y — configure inside GTM (Google tag), NOT in this file

# USD→HKD rate for WeChat price display when API has no recurringMonthHkd (default 7.8)
# VITE_USD_HKD_RATE=7.8

# PayPal Subscriptions (omit to show CTA buttons instead of PayPal widgets on /pricing)
VITE_PAYPAL_CLIENT_ID=AYy3_F_9lnuoCdcktpWG_PJlGolYuUvJRsjeQMIzPsb2U0epjYoLxUmOvJS4bG-uYfzMFs65QIBWb3Jn
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
